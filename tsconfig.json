{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "src",
    "declaration": true,
    "jsx": "react-jsx",
    "sourceMap": true,
    "paths": {
      "#application/*": ["./src/application/*"],
      "#domain/*": ["./src/domain/*"],
      "#infrastructure/*": ["./src/infrastructure/*"],
      "#ui/*": ["./src/ui/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
